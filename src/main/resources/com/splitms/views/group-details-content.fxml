<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.splitms.controllers.GroupDetailsContentController"
      spacing="14.0"
      styleClass="dashboard-content group-details-page-content">
    <padding>
        <Insets top="24.0" right="22.0" bottom="24.0" left="18.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <Button onAction="#onBack" styleClass="outline-button" text="Back to Groups" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onEditGroup" styleClass="outline-button" text="Edit Group" />
        <Button onAction="#onDeleteGroup" styleClass="outline-button danger-button" text="Delete Group" />
    </HBox>

    <VBox spacing="4.0">
        <Label fx:id="titleLabel" styleClass="groups-title" text="Group" />
        <Label fx:id="subtitleLabel" styleClass="groups-subtitle" text="Group description" />
    </VBox>

    <Label fx:id="statusLabel" styleClass="status-label" text="" />
</VBox>
