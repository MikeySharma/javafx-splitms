<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.splitms.controllers.DashboardContentController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            styleClass="dashboard-scroll">
    <content>
        <VBox spacing="20.0" styleClass="dashboard-content">
            <padding>
                <Insets top="24.0" right="20.0" bottom="24.0" left="18.0" />
            </padding>

            <!-- Title and Welcome Section -->
            <VBox spacing="4.0">
                <Label styleClass="dashboard-title" text="Dashboard" />
                <Label fx:id="welcomeLabel" styleClass="dashboard-subtitle" text="Welcome back!" />
            </VBox>

            <!-- Settlement Cards Section -->
            <HBox spacing="14.0">
                <!-- You Owe Card -->
                <VBox prefWidth="360.0" spacing="10.0" styleClass="dashboard-stat-card">
                    <Label styleClass="dashboard-stat-label" text="You Owe" />
                    <VBox fx:id="youOweContainer" spacing="8.0" styleClass="settlement-items" />
                </VBox>

                <!-- You're Owed Card -->
                <VBox prefWidth="360.0" spacing="10.0" styleClass="dashboard-stat-card">
                    <Label styleClass="dashboard-stat-label" text="You're Owed" />
                    <VBox fx:id="youAreOwedContainer" spacing="8.0" styleClass="settlement-items" />
                </VBox>
            </HBox>

            <!-- Net Balance Card -->
            <VBox spacing="8.0" styleClass="dashboard-stat-card">
                <Label fx:id="netBalanceLabel" styleClass="dashboard-stat-label" text="Net Balance: Calculating..." />
            </VBox>

            <!-- Recent Expenses Section -->
            <VBox spacing="10.0" styleClass="dashboard-panel">
                <Label styleClass="dashboard-panel-title" text="Recent Expenses" />
                <VBox fx:id="recentExpensesContainer" spacing="8.0" styleClass="recent-list" />
            </VBox>

            <!-- Recent Transactions Section -->
            <VBox spacing="10.0" styleClass="dashboard-panel">
                <Label styleClass="dashboard-panel-title" text="Recent Settlements" />
                <VBox fx:id="recentTransactionsContainer" spacing="8.0" styleClass="recent-list" />
            </VBox>
        </VBox>
    </content>
</ScrollPane>
