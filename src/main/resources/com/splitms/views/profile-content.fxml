<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.splitms.controllers.ProfileContentController"
      spacing="12.0"
      styleClass="dashboard-content">
    <padding>
        <Insets top="24.0" right="20.0" bottom="24.0" left="18.0" />
    </padding>

    <Label styleClass="groups-title" text="Profile" />
    <Label styleClass="groups-subtitle" text="Update your account details" />

    <Label styleClass="form-label" text="Name" />
    <TextField fx:id="nameField" styleClass="text-input" />

    <Label styleClass="form-label" text="Email" />
    <TextField fx:id="emailField" styleClass="text-input" />

    <Button onAction="#onSaveProfile" styleClass="primary-button" text="Save Profile" />
    <Label fx:id="messageLabel" styleClass="status-label" text="" />
</VBox>
